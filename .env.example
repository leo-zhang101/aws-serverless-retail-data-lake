# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCOUNT_ID=123456789012

# S3 Bucket Names (will be set by Terraform outputs)
# RAW_BUCKET=retail-raw-xxx
# BRONZE_BUCKET=retail-bronze-xxx
# SILVER_BUCKET=retail-silver-xxx
# GOLD_BUCKET=retail-gold-xxx

# Glue
GLUE_DATABASE=retail_analytics
GLUE_CRAWLER_ROLE_ARN=arn:aws:iam::123456789012:role/glue-crawler-role

# Athena
ATHENA_WORKGROUP=retail-analytics
ATHENA_OUTPUT_BUCKET=retail-athena-results-xxx

# dbt (for local development)
DBT_TARGET=athena
DBT_SCHEMA=retail_analytics
